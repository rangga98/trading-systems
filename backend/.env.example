# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/trading_sim

# Application
APP_NAME="IDX Trading Simulator"
DEBUG=false
LOG_LEVEL=INFO

# yfinance settings
YFINANCE_DELAY=0.5
YFINANCE_RETRIES=3
YFINANCE_CACHE_DIR=/tmp/yfinance

# Timezone
TIMEZONE=Asia/Jakarta

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
